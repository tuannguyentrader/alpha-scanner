datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String             @id @default(cuid())
  email        String             @unique
  passwordHash String
  name         String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  settings     UserSettings?
  strategies   StrategyTemplate[]
  apiKeys      ApiKey[]
}

model ApiKey {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  key            String    @unique
  name           String
  plan           String    @default("free")
  requestsToday  Int       @default(0)
  lastResetAt    DateTime  @default(now())
  expiresAt      DateTime?
  enabled        Boolean   @default(true)
  createdAt      DateTime  @default(now())

  @@index([userId])
  @@index([key])
}

model StrategyTemplate {
  id          String   @id @default(cuid())
  userId      String?  // null = preset/system template
  name        String
  description String?
  config      String   // JSON: { symbols: string[], mode: string, riskProfile: string, leverage: number, capital: number }
  isPublic    Boolean  @default(false)
  shareSlug   String?  @unique // for public sharing links
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isPublic])
  @@index([shareSlug])
}

model SignalRecord {
  id         String   @id @default(cuid())
  symbol     String
  mode       String
  direction  String   // BUY or SELL
  entryPrice Float
  tp1        Float
  sl         Float
  confidence Int
  outcome    String   @default("PENDING") // PENDING, HIT_TP1, HIT_SL, EXPIRED
  createdAt  DateTime @default(now())
  resolvedAt DateTime?

  @@index([symbol, mode])
  @@index([outcome])
  @@index([createdAt])
}

model WebhookConfig {
  id        String   @id @default(cuid())
  url       String
  secret    String?  // optional signing secret
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  logs      WebhookLog[]
}

model WebhookLog {
  id          String        @id @default(cuid())
  webhookId   String
  webhook     WebhookConfig @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  symbol      String
  direction   String
  statusCode  Int?
  success     Boolean
  attempt     Int           @default(1)
  error       String?
  createdAt   DateTime      @default(now())

  @@index([webhookId])
  @@index([createdAt])
}

model UserSettings {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  watchlist        String   @default("[]")
  preferredMode    String   @default("swing")
  riskProfile      String   @default("balanced")
  leverage         Float    @default(100)
  capital          Float    @default(10000)
  telegramBotToken String?
  telegramChatId   String?
  updatedAt        DateTime @updatedAt
}
