datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

model User {
  id           String             @id @default(cuid())
  email        String             @unique
  passwordHash String
  name         String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  settings     UserSettings?
  strategies   StrategyTemplate[]
  apiKeys      ApiKey[]
  subscription Subscription?
  strategyListings  StrategyListing[]  @relation("StrategyListings")
  strategyPurchases StrategyPurchase[] @relation("StrategyPurchases")
}

model Subscription {
  id                    String    @id @default(cuid())
  userId                String    @unique
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeCustomerId      String?   @unique
  stripeSubscriptionId  String?   @unique
  plan                  String    @default("free") // free, pro, elite
  status                String    @default("active") // active, canceled, past_due
  currentPeriodEnd      DateTime?
  cancelAtPeriodEnd     Boolean   @default(false)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model ApiKey {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  key            String    @unique
  name           String
  plan           String    @default("free")
  requestsToday  Int       @default(0)
  lastResetAt    DateTime  @default(now())
  expiresAt      DateTime?
  enabled        Boolean   @default(true)
  createdAt      DateTime  @default(now())

  @@index([userId])
  @@index([key])
}

model StrategyTemplate {
  id          String   @id @default(cuid())
  userId      String?  // null = preset/system template
  name        String
  description String?
  config      String   // JSON: { symbols: string[], mode: string, riskProfile: string, leverage: number, capital: number }
  isPublic    Boolean  @default(false)
  shareSlug   String?  @unique // for public sharing links
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isPublic])
  @@index([shareSlug])
}

model SignalRecord {
  id         String   @id @default(cuid())
  symbol     String
  mode       String
  direction  String   // BUY or SELL
  entryPrice Float
  tp1        Float
  sl         Float
  confidence Int
  outcome    String   @default("PENDING") // PENDING, HIT_TP1, HIT_SL, EXPIRED
  createdAt  DateTime @default(now())
  resolvedAt DateTime?

  @@index([symbol, mode])
  @@index([outcome])
  @@index([createdAt])
}

model WebhookConfig {
  id        String   @id @default(cuid())
  url       String
  secret    String?  // optional signing secret
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  logs      WebhookLog[]
}

model WebhookLog {
  id          String        @id @default(cuid())
  webhookId   String
  webhook     WebhookConfig @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  symbol      String
  direction   String
  statusCode  Int?
  success     Boolean
  attempt     Int           @default(1)
  error       String?
  createdAt   DateTime      @default(now())

  @@index([webhookId])
  @@index([createdAt])
}

model UserSettings {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  watchlist        String   @default("[]")
  preferredMode    String   @default("swing")
  riskProfile      String   @default("balanced")
  leverage         Float    @default(100)
  capital          Float    @default(10000)
  telegramBotToken String?
  telegramChatId   String?
  alertWatchlist   String   @default("[]")
  alertRules       String   @default("[]")
  paperTradingState String?
  signalHistory    String   @default("[]")
  equitySnapshots  String   @default("[]")
  tradeRecords     String   @default("[]")
  pushSignalAlerts Boolean  @default(true)
  pushTpAlerts     Boolean  @default(true)
  pushSlAlerts     Boolean  @default(true)
  pushDailyReport  Boolean  @default(true)
  updatedAt        DateTime @updatedAt
}

model Signal {
  id          String   @id @default(cuid())
  symbol      String
  timeframe   String
  direction   String
  entryPrice  Float
  stopLoss    Float
  takeProfit  Float
  confidence  Int
  strategy    String
  status      String   @default("ACTIVE")
  triggeredAt DateTime?
  closedAt    DateTime?
  pnl         Float?
  createdAt   DateTime @default(now())

  @@index([symbol])
  @@index([status])
  @@index([createdAt])
}

model Backtest {
  id            String   @id @default(cuid())
  strategyName  String
  symbol        String
  timeframe     String
  startDate     DateTime
  endDate       DateTime
  totalTrades   Int
  winRate       Float
  profitFactor  Float
  maxDrawdown   Float
  netProfit     Float
  sharpeRatio   Float?
  config        String
  results       String
  createdAt     DateTime @default(now())

  @@index([strategyName])
  @@index([symbol])
}

model Alert {
  id          String    @id @default(cuid())
  symbol      String
  type        String
  condition   String
  targetPrice Float?
  message     String
  triggered   Boolean   @default(false)
  triggeredAt DateTime?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())

  @@index([symbol])
  @@index([active])
}

model TradingSession {
  id          String   @id @default(cuid())
  symbol      String
  direction   String
  entryPrice  Float
  exitPrice   Float?
  quantity    Float
  leverage    Float    @default(1)
  status      String   @default("OPEN")
  pnl         Float?
  pnlPercent  Float?
  notes       String?
  openedAt    DateTime @default(now())
  closedAt    DateTime?

  @@index([symbol])
  @@index([status])
}

model UserPreference {
  id                String  @id @default(cuid())
  userId            String  @unique
  theme             String  @default("dark")
  defaultTimeframe  String  @default("4h")
  defaultSymbols    String  @default("[]")
  notifications     Boolean @default(true)
  emailAlerts       Boolean @default(false)
  soundAlerts       Boolean @default(true)
  chartType         String  @default("candlestick")
  language          String  @default("en")
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String?
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
}

model StrategyListing {
  id               String   @id @default(cuid())
  authorId         String
  author           User     @relation("StrategyListings", fields: [authorId], references: [id], onDelete: Cascade)
  name             String
  description      String   @default("")
  price            Float
  indicatorsConfig String
  backtestResults  String   @default("{}")
  isPublished      Boolean  @default(false)
  assetType        String   @default("crypto")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  purchases        StrategyPurchase[]

  @@index([authorId])
  @@index([isPublished])
  @@index([price])
}

model StrategyPurchase {
  id                    String          @id @default(cuid())
  buyerId               String
  buyer                 User            @relation("StrategyPurchases", fields: [buyerId], references: [id], onDelete: Cascade)
  listingId             String
  listing               StrategyListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  stripePaymentIntentId String
  purchasedAt           DateTime        @default(now())

  @@unique([buyerId, listingId])
  @@index([buyerId])
  @@index([listingId])
}
